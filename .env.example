# OpenAI（建築登録フォームの「AIで下書き」オプション。未設定時はボタンが 503）
# OPENAI_API_KEY=sk-...
# Optional: 既定は gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Google Maps JavaScript API
# Get your key: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps JavaScript API, Places API (legacy: photos), Places API (New) for /api/places-details, /api/places-autocomplete, /api/places-prefill
# Cloud Console で「Places API」が有効なこと（新 API は同一キーで利用可）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional: server-only key for /api/places-photo and /api/places-details (falls back to NEXT_PUBLIC_* if unset)
# GOOGLE_MAPS_API_KEY=your_server_restricted_key
# Optional: Map ID for Advanced Markers (omit to use DEMO_MAP_ID)
# Create at: Google Cloud > Google Maps Platform > Map Management
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id

# Firebase (Firestore)
# 建築の作成・更新 API（POST/PUT /api/buildings）は Firebase Admin 用サービスアカウント JSON（1 行）が必須です。
# Firebase Console > プロジェクト設定 > サービスアカウント > 新しい秘密鍵の生成
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# 集計 API（/api/buildings/[id]/stats）が buildings を update できるよう、ルールで許可が必要です。
# Google Places / Maps のデータを DB に何を載せるかの方針は docs/google-maps-platform-data-policy.md を参照。
# POST /api/buildings/[id]/place-info-verified（鮮度の「情報確認日」更新）用。未設定時は 503。
# PLACE_INFO_VERIFY_SECRET=long_random_string

# Get config: Firebase Console > Project settings > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
